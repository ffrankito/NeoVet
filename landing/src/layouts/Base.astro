---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "NeoVet — Centro Veterinario",
  description = "Centro reproductivo canino y veterinaria en Rosario. Cirugía, cardiología, vacunación, peluquería canina y más. Atención profesional para tu mascota.",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f766e" />

    <!-- Google Fonts: DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={description} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/twitter-image.png" />
    <meta name="twitter:image:alt" content={description} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-neutral-50 text-neutral-800 antialiased">
    <slot />

    <!-- Chat Widget -->
    <div id="chat-container" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">
      <div
        id="chat-box"
        class="hidden w-[380px] h-[560px] rounded-3xl shadow-2xl overflow-hidden border border-neutral-200 bg-white"
      >
        <iframe
          src="https://neo-vet-widget.vercel.app"
          class="w-full h-full border-0"
          title="Asistente NeoVet"
        />
      </div>

      <button
        id="chat-toggle"
        class="w-14 h-14 rounded-full bg-primary-500 hover:bg-primary-600 text-white shadow-lg flex items-center justify-center transition-all"
        aria-label="Abrir chat"
      >
        <svg id="icon-open" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
        <svg id="icon-close" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <script>
      const toggle = document.getElementById("chat-toggle");
      const box = document.getElementById("chat-box");
      const iconOpen = document.getElementById("icon-open");
      const iconClose = document.getElementById("icon-close");

      toggle?.addEventListener("click", () => {
        box?.classList.toggle("hidden");
        iconOpen?.classList.toggle("hidden");
        iconClose?.classList.toggle("hidden");
      });
    </script>
  </body>
</html>