---
const reviews = [
  {
    name: "Agustina Badaracco",
    text: "Pauuuuu es la número uno. La salvó a mi nunita a parvovirus y moquillo. Agradecida eternamente.",
    rating: 5,
  },
  {
    name: "Abril Sequeira",
    text: "Estábamos volviendo de viaje, tuvimos una urgencia y nos encontramos con Neovet. Excelente atención y la veterinaria súper profesional, nos fuimos satisfechos y encantados con la atención que le dieron a Gino. Muchas gracias!!",
    rating: 5,
  },
  {
    name: "Nadia Sulsenti",
    text: "Tener a Paula en nuestro barrio es una bendición. Fue un ángel que le salvó la vida a nuestro cachorrito al responder tan rápidamente nuestra llamada. Siempre vamos a estar agradecidos!!! Una profesional con pasión y dedicación hacia sus clientes de 4 patas.",
    rating: 5,
  },
];
---

<section id="resenas" class="bg-white py-section" data-animate>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary-600">
        Reseñas
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
        Lo que dicen nuestros clientes
      </h2>
    </div>

    <div class="mt-8 sm:mt-16 grid gap-4 sm:gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {reviews.map((review) => (
        <div class="flex flex-col rounded-2xl border border-neutral-200 bg-neutral-50 p-4 sm:p-6">
          <!-- Quote mark -->
          <svg class="h-6 w-6 sm:h-8 sm:w-8 text-primary-200" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5 3.871 3.871 0 0 1-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5 3.871 3.871 0 0 1-2.748-1.179z" />
          </svg>
          <!-- Stars -->
          <div class="mt-3 flex gap-0.5 text-accent-400" aria-label={`${review.rating} de 5 estrellas`}>
            {Array.from({ length: review.rating }).map(() => (
              <svg class="h-4 w-4 sm:h-5 sm:w-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Review text -->
          <blockquote class="mt-2 sm:mt-4 flex-1 text-sm leading-relaxed text-neutral-600">
            "{review.text}"
          </blockquote>

          <!-- Author -->
          <div class="mt-4 flex items-center gap-3 border-t border-neutral-200 pt-3 sm:pt-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-100 text-sm font-semibold text-primary-700">
              {review.name.split(" ").map((n) => n[0]).join("")}
            </div>
            <p class="text-sm font-medium text-neutral-800">{review.name}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href="https://maps.app.goo.gl/NeoVetRosario"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 transition-colors hover:text-primary-800"
      >
        Ver todas las reseñas en Google
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>
  </div>
</section>
<style>
  /* Animación de entrada de las cards */
  #resenas [class*="grid"] > div {
    animation: fadeInUp 0.6s ease-out both;
  }

  #resenas [class*="grid"] > div:nth-child(1) {
    animation-delay: 0.1s;
  }

  #resenas [class*="grid"] > div:nth-child(2) {
    animation-delay: 0.2s;
  }

  #resenas [class*="grid"] > div:nth-child(3) {
    animation-delay: 0.3s;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Efecto hover en las cards */
  #resenas [class*="rounded-2xl"] {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  #resenas [class*="rounded-2xl"]:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    border-color: #10b981;
  }

  /* Animación del ícono de comillas */
  #resenas svg:first-child {
    transition: all 0.3s ease;
  }

  #resenas [class*="rounded-2xl"]:hover svg:first-child {
    transform: scale(1.1) rotate(-5deg);
    color: #10b981;
  }

  /* Animación de las estrellas */
  #resenas [aria-label*="estrellas"] svg {
    display: inline-block;
    animation: starPop 0.6s ease-out both;
  }

  #resenas [aria-label*="estrellas"] svg:nth-child(1) { animation-delay: 0.1s; }
  #resenas [aria-label*="estrellas"] svg:nth-child(2) { animation-delay: 0.2s; }
  #resenas [aria-label*="estrellas"] svg:nth-child(3) { animation-delay: 0.3s; }
  #resenas [aria-label*="estrellas"] svg:nth-child(4) { animation-delay: 0.4s; }
  #resenas [aria-label*="estrellas"] svg:nth-child(5) { animation-delay: 0.5s; }

  @keyframes starPop {
    0% {
      opacity: 0;
      transform: scale(0);
    }
    50% {
      transform: scale(1.2);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Hover en las estrellas */
  #resenas [class*="rounded-2xl"]:hover [aria-label*="estrellas"] svg {
    animation: starShine 0.5s ease-in-out;
  }

  @keyframes starShine {
    0%, 100% {
      transform: scale(1);
      filter: brightness(1);
    }
    50% {
      transform: scale(1.1);
      filter: brightness(1.3);
    }
  }

  /* Animación del avatar */
  #resenas [class*="rounded-full"] {
    transition: all 0.3s ease;
  }

  #resenas [class*="rounded-2xl"]:hover [class*="rounded-full"] {
    transform: scale(1.1) rotate(5deg);
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
  }

  /* Efecto de brillo en hover */
  #resenas [class*="rounded-2xl"]::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent,
      rgba(16, 185, 129, 0.1),
      transparent
    );
    transform: rotate(45deg);
    transition: all 0.6s ease;
    opacity: 0;
    pointer-events: none;
  }

  #resenas [class*="rounded-2xl"]:hover::before {
    opacity: 1;
    left: 100%;
  }

  /* Mejora del link "Ver todas" */
  #resenas .mt-12 a {
    position: relative;
    transition: all 0.3s ease;
  }

  #resenas .mt-12 a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: currentColor;
    transition: width 0.3s ease;
  }

  #resenas .mt-12 a:hover::after {
    width: 100%;
  }

  #resenas .mt-12 a svg {
    transition: transform 0.3s ease;
  }

  #resenas .mt-12 a:hover svg {
    transform: translate(4px, -4px);
  }
</style>