---
const whatsappUrl =
  "https://api.whatsapp.com/send/?phone=543413101194&text=URGENCIA%3A%20necesito%20atenci%C3%B3n%20inmediata&type=phone_number&app_absent=0";

const motivos = [
  { value: "turno", label: "Solicitar turno" },
  { value: "ecografia", label: "Ecografía a domicilio" },
  { value: "reproduccion", label: "Reproducción / Neonatología" },
  { value: "cirugia", label: "Cirugía" },
  { value: "peluqueria", label: "Peluquería canina" },
  { value: "urgencia", label: "Urgencia" },
  { value: "otro", label: "Otro" },
];
---

<section id="contacto" class="relative bg-gradient-to-b from-neutral-50 to-white py-24 sm:py-32">
  <!-- Background blur decorations -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute left-1/2 top-0 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary-500/10 blur-3xl"></div>
    <div class="absolute right-0 top-1/2 h-64 w-64 translate-x-1/2 -translate-y-1/2 rounded-full bg-accent-500/10 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      
      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 rounded-full bg-primary-100 px-4 py-2 text-sm font-semibold text-primary-700 mb-4">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Contactoa
        </div>
        <h2 class="text-4xl font-bold tracking-tight text-neutral-900 sm:text-5xl mb-4">
          Dejanos tu consulta
        </h2>
        <p class="text-lg text-neutral-600">
          Completá el formulario y te respondemos por WhatsApp o email.
        </p>
      </div>

      <!-- Form card -->
      <form id="contact-form" class="relative group">
        
        <!-- Glow border on hover -->
        <div class="absolute -inset-0.5 rounded-3xl bg-gradient-to-r from-primary-500 to-accent-500 opacity-0 blur transition duration-500 group-hover:opacity-20"></div>
        
        <div class="relative rounded-3xl border border-neutral-200 bg-white p-8 shadow-lg sm:p-10">
          <div class="space-y-6">

            <!-- Nombre -->
            <div>
              <label for="nombre" class="block text-sm font-semibold text-neutral-900 mb-2">
                Nombre completo <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                class="block w-full rounded-xl border-2 border-neutral-200 bg-white px-4 py-3 text-neutral-900 placeholder-neutral-400 transition-all focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-500/10"
                placeholder="Juan Pérez"
              />
            </div>

            <!-- Teléfono + Email -->
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="telefono" class="block text-sm font-semibold text-neutral-900 mb-2">
                  WhatsApp <span class="text-red-500">*</span>
                </label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  required
                  class="block w-full rounded-xl border-2 border-neutral-200 bg-white px-4 py-3 text-neutral-900 placeholder-neutral-400 transition-all focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-500/10"
                  placeholder="341 310-1194"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-neutral-900 mb-2">
                  Email <span class="text-xs text-neutral-500 font-normal">(opcional)</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="block w-full rounded-xl border-2 border-neutral-200 bg-white px-4 py-3 text-neutral-900 placeholder-neutral-400 transition-all focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-500/10"
                  placeholder="tu@email.com"
                />
              </div>
            </div>

            <!-- Mascota + Motivo -->
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="mascota" class="block text-sm font-semibold text-neutral-900 mb-2">
                  Nombre de tu mascota <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="mascota"
                  name="mascota"
                  required
                  class="block w-full rounded-xl border-2 border-neutral-200 bg-white px-4 py-3 text-neutral-900 placeholder-neutral-400 transition-all focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-500/10"
                  placeholder="Bobby"
                />
              </div>
              <div>
                <label for="motivo" class="block text-sm font-semibold text-neutral-900 mb-2">
                  Motivo <span class="text-red-500">*</span>
                </label>
                <select
                  id="motivo"
                  name="motivo"
                  required
                  class="block w-full rounded-xl border-2 border-neutral-200 bg-white px-4 py-3 text-neutral-900 transition-all focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-500/10"
                >
                  <option value="" disabled selected>Seleccioná un motivo</option>
                  {motivos.map((m) => (
                    <option value={m.value}>{m.label}</option>
                  ))}
                </select>
              </div>
            </div>

            <!-- Mensaje -->
            <div id="mensaje-row">
              <label for="mensaje" class="block text-sm font-semibold text-neutral-900 mb-2">
                Mensaje
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="4"
                class="block w-full resize-none rounded-xl border-2 border-neutral-200 bg-white px-4 py-3 text-neutral-900 placeholder-neutral-400 transition-all focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-500/10"
                placeholder="Contanos en qué podemos ayudarte..."
              ></textarea>
            </div>

            <!-- Submit Button -->
            <div id="submit-row">
              <button
                type="submit"
                class="group/btn relative w-full overflow-hidden rounded-xl bg-gradient-to-r from-primary-500 to-primary-600 px-8 py-4 text-base font-semibold text-white shadow-lg transition-all hover:shadow-xl hover:scale-[1.02] active:scale-[0.98]"
              >
                <span class="relative z-10 flex items-center justify-center gap-2">
                  Enviar consulta
                  <svg class="h-5 w-5 transition-transform group-hover/btn:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </span>
                <!-- Shimmer effect -->
                <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent transition-transform duration-700 group-hover/btn:translate-x-full"></div>
              </button>
              <p class="mt-4 text-center text-sm text-neutral-500">
                Te respondemos en menos de 24hs
              </p>
            </div>

            <!-- Urgency Escape -->
            <div id="urgency-escape" class="hidden">
              <div class="rounded-2xl bg-gradient-to-br from-red-50 to-orange-50 border-2 border-red-200 p-8 text-center">
                <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-red-100">
                  <svg class="h-8 w-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-neutral-900 mb-2">
                  ¿Es una urgencia?
                </h3>
                <p class="text-neutral-700 mb-6">
                  Para atención inmediata, contactanos directamente:
                </p>
                <a
                  href={whatsappUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-xl bg-whatsapp px-8 py-4 text-base font-semibold text-white shadow-lg transition-all hover:bg-whatsapp-dark hover:shadow-xl hover:scale-105 active:scale-95"
                >
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                  </svg>
                  WhatsApp de urgencia
                </a>
                <p class="mt-4 text-sm text-neutral-600">
                  O llamanos al <a href="tel:+543413101194" class="font-semibold text-primary-600 hover:text-primary-700">(341) 310-1194</a>
                </p>
              </div>
            </div>

          </div>
        </div>
      </form>

    </div>
  </div>
</section>

<script>
  const select = document.getElementById("motivo") as HTMLSelectElement | null;
  const mensajeRow = document.getElementById("mensaje-row");
  const submitRow = document.getElementById("submit-row");
  const urgencyEscape = document.getElementById("urgency-escape");

  select?.addEventListener("change", () => {
    const isUrgency = select.value === "urgencia";
    
    if (mensajeRow && submitRow && urgencyEscape) {
      if (isUrgency) {
        mensajeRow.classList.add("hidden");
        submitRow.classList.add("hidden");
        urgencyEscape.classList.remove("hidden");
      } else {
        mensajeRow.classList.remove("hidden");
        submitRow.classList.remove("hidden");
        urgencyEscape.classList.add("hidden");
      }
    }
  });
</script>