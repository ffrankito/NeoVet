---
const whatsappUrl =
  "https://api.whatsapp.com/send/?phone=543413101194&text&type=phone_number&app_absent=0";
---

<nav class="fixed top-0 z-50 w-full">
  <div class="mx-auto flex h-16 lg:h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo (raw img to preserve PNG transparency — Astro's Image optimizer strips it) -->
    <a href="#inicio" class="flex items-center">
      <img
        src="/neovet-logo.png"
        alt="NeoVet"
        class="h-12 lg:h-20 w-auto"
      />
    </a>

    <!-- Right side: two links -->
    <div class="flex items-center gap-4">
      <a
        href="#servicios"
        class="text-sm font-medium text-white/80 transition-colors hover:text-white"
      >
        Servicios
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full border border-white/30 px-4 py-1.5 text-sm font-medium text-white transition-all hover:border-white/60 hover:bg-white/10"
      >
        Contactanos
      </a>
    </div>
  </div>
</nav>
