---
import { Image } from 'astro:assets';
import logo from '../assets/logo/loco_con_fondo.jpg';

const navLinks = [
  { label: "Inicio", href: "#inicio" },
  { label: "Servicios", href: "#servicios" },
  { label: "Nosotros", href: "#nosotros" },
  { label: "Horarios", href: "#horarios" },
  { label: "Ubicación", href: "#ubicacion" },
  { label: "Reseñas", href: "#resenas" },
];

const whatsappUrl =
  "https://api.whatsapp.com/send/?phone=543413101194&text&type=phone_number&app_absent=0";
---

<nav style="background-color: #fffffe;" class="fixed top-0 z-50 w-full border-b border-neutral-200">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="#inicio" class="flex h-full items-center">
      <Image
        src={logo}
        alt="NeoVet"
        height={64}
        class="h-full w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-6 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-neutral-600 transition-colors hover:text-primary-700"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden rounded-lg bg-whatsapp px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-whatsapp-dark md:inline-flex"
    >
      Contactanos
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-neutral-600 hover:bg-neutral-100 md:hidden"
      aria-expanded="false"
      aria-label="Abrir menú de navegación"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-neutral-200 bg-white md:hidden">
    <ul class="space-y-1 px-4 py-3">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link block rounded-md px-3 py-2 text-sm font-medium text-neutral-600 hover:bg-neutral-100 hover:text-primary-700"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 block rounded-lg bg-whatsapp px-4 py-2 text-center text-sm font-semibold text-white shadow-sm hover:bg-whatsapp-dark"
        >
          Contactanos
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
      menu.classList.toggle("hidden");
    });
    menu.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>
