---
interface Props {
  href: string;
  cta: string;
  icon?: string;
  title: string;
  description: string;
  badge?: string;
  featured?: boolean;
}

const { href, cta, icon, title, description, badge, featured = false } = Astro.props;
---

<a 
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="service-card-wrapper group block"
>
  <div class="service-card">
    <div class="service-card-inner">
      
      {badge && (
        <span class="inline-block rounded-full bg-blue-500/20 px-2.5 py-0.5 text-xs font-semibold text-blue-300 mb-3">
          {badge}
        </span>
      )}

      <!-- Icon -->
      <div class="mb-4">
        <slot name="icon">
          {icon && <span class="text-5xl">{icon}</span>}
        </slot>
      </div>

      <!-- Title -->
      <h3 class="text-xl font-bold text-white mb-2">
        {title}
      </h3>

      <!-- Description -->
      <p class="text-sm text-white/70 leading-relaxed mb-4">
        {description}
      </p>

      <!-- CTA -->
      <div class="inline-flex items-center gap-1.5 text-sm font-semibold text-blue-300 group-hover:text-blue-200 transition-colors">
        {cta}
        <svg
          class="h-4 w-4 transition-transform group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
          />
        </svg>
      </div>

    </div>
  </div>
</a>

<style>
  .service-card-wrapper {
    width: 100%;
    max-width: 320px;
  }

  .service-card {
    width: 100%;
    height: 340px;
    background-image: linear-gradient(163deg, #e660a3 0%, #46f5ac 100%);
    border-radius: 20px;
    padding: 4px;
    transition: all 0.3s ease;
    position: relative;
  }

  .service-card:hover {
    box-shadow: 
      0 0 30px 1px rgba(236, 121, 211, 0.4),
      0 0 60px 2px rgba(96, 165, 250, 0.2);
    transform: translateY(-4px);
  }

  .service-card-inner {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f8f3f3 0%,  #f0bad5 100%);
    border-radius: 18px;
    padding: 1.5rem;
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .service-card:hover .service-card-inner {
    transform: scale(0.98);
  }

  @media (max-width: 640px) {
    .service-card {
      height: 300px;
    }
  }
</style>