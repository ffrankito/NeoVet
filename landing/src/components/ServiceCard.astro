---
interface Props {
  href: string;
  cta: string;
  icon?: string;
  title: string;
  description: string;
  badge?: string;
  featured?: boolean;
}

const { href, cta, icon, title, description, badge, featured = false } = Astro.props;
---

<div class:list={[
  "group rounded-2xl p-4 sm:p-6 transition-all hover:shadow-lg",
  featured
    ? "border-2 border-primary-200 bg-primary-50/50 hover:border-primary-400"
    : "border border-neutral-200 bg-neutral-50 hover:border-primary-300"
]}>
  {badge && (
    <span class="inline-block rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-semibold text-primary-700">
      {badge}
    </span>
  )}

  <!-- Icon: slot or emoji fallback -->
  <div class:list={[featured ? "mt-3" : "mt-0 sm:mb-4"]}>
    <slot name="icon">
      {icon && <span class="text-4xl">{icon}</span>}
    </slot>
  </div>

  <h3 class:list={[
    "font-semibold text-neutral-900",
    featured ? "mt-3 text-lg" : "mt-2 text-sm sm:text-lg"
  ]}>
    {title}
  </h3>

  <p class:list={[
    "leading-relaxed text-neutral-500",
    featured ? "mt-2 text-sm" : "mt-1 hidden text-sm sm:mt-2 sm:block"
  ]}>
    {description}
  </p>

  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      "mt-3 inline-flex items-center gap-1 text-sm font-medium transition-colors",
      featured
        ? "text-primary-700 hover:text-primary-900"
        : "text-primary-600 hover:text-primary-800"
    ]}
  >
    {cta}
    <svg
      class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
      />
    </svg>
  </a>
</div>
