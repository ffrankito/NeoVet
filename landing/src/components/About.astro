<section id="nosotros" class="bg-neutral-50 py-section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Photo placeholder -->
      <div class="relative">
        <div class="aspect-[4/5] overflow-hidden rounded-2xl bg-neutral-200">
          <!-- PLACEHOLDER: replace with real photo of Paula -->
          <div class="flex h-full items-center justify-center text-neutral-400">
            <svg class="h-24 w-24" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
            </svg>
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 rounded-xl bg-primary-600 px-6 py-3 text-white shadow-lg">
          <p class="text-sm font-medium">Médica Veterinaria</p>
          <p class="text-xs text-primary-200">Egresada UNR — Casilda</p>
        </div>
      </div>

      <!-- Bio -->
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-600">
          Sobre nosotros
        </p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
          <!-- PLACEHOLDER: confirm name spelling with Paula -->
          Dra. Paula Silveyra
        </h2>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-neutral-600">
          <!-- PLACEHOLDER: confirm/rewrite bio with Paula -->
          <p>
            Médica veterinaria egresada de la Facultad de Ciencias Veterinarias de Casilda (UNR). 
            Dedicada especialmente a los animales de compañía, con foco en razas braquicefálicas 
            y reproducción canina.
          </p>
          <p>
            En NeoVet combinamos formación profesional continua con una atención cercana y 
            comprometida. Cada mascota que llega a nuestra consulta recibe el mismo cuidado 
            que le daríamos a las nuestras.
          </p>
        </div>
        <div class="mt-8 flex items-center gap-4">
          <div class="flex items-center gap-2 rounded-lg bg-primary-50 px-4 py-2">
            <span class="text-2xl">🐾</span>
            <div>
              <p class="text-sm font-semibold text-primary-800">Especialidad</p>
              <p class="text-xs text-primary-600">Bulldogs y braquicefálicos</p>
            </div>
          </div>
          <div class="flex items-center gap-2 rounded-lg bg-accent-50 px-4 py-2">
            <span class="text-2xl">🏥</span>
            <div>
              <p class="text-sm font-semibold text-accent-800">Guardia</p>
              <p class="text-xs text-accent-600">Obstétrica 24hs</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
