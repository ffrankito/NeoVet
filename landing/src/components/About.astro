---
import { Image } from 'astro:assets';
import paulaImg from '../assets/images/paula_and_vet.jpeg';
---

<section id="nosotros" class="bg-neutral-50 py-section" data-animate>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Photo -->
      <div class="overflow-hidden rounded-2xl">
        <Image
          src={paulaImg}
          alt="Paula Silveyra — Médica Veterinaria NeoVet"
          class="h-full w-full object-cover"
          width={600}
          height={750}
        />
      </div>

      <!-- Bio -->
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-600">
          Sobre nosotros
        </p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
          Médica Veterinaria Paula Silveyra
        </h2>
        <p class="mt-1 text-sm text-neutral-500 font-medium">Mat. 2046</p>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-neutral-600">
          <p>
            Especialista con formación académica de posgrado orientada a la excelencia clínica.
            Diplomada en medicina de braquicefálicos y Máster en ecografía, dedicada a integrar
            la tecnología y el conocimiento especializado para el bienestar de cada paciente.
          </p>
        </div>
        <div class="mt-8 flex items-center gap-4">
          <div class="flex items-center gap-2 rounded-lg bg-primary-50 px-4 py-2">
            <span class="text-2xl">🐾</span>
            <div>
              <p class="text-sm font-semibold text-primary-800">Especialidad</p>
              <p class="text-xs text-primary-600">Bulldogs y braquicefálicos</p>
            </div>
          </div>
          <div class="flex items-center gap-2 rounded-lg bg-accent-50 px-4 py-2">
            <span class="text-2xl">🏥</span>
            <div>
              <p class="text-sm font-semibold text-accent-800">Guardia</p>
              <p class="text-xs text-accent-600">Obstétrica 24hs</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>