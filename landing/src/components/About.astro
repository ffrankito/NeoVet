---
import { Image } from 'astro:assets';
import paulaImg from '../assets/images/paula_and_vet.jpeg';
---

<section id="nosotros" class="relative overflow-hidden py-24 sm:py-32">
  <!-- Animated background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(16,185,129,0.05)_0%,transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(236,72,153,0.05)_0%,transparent_50%)]"></div>
    <div class="animated-grid"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      
      <!-- Photo side -->
      <div class="relative">
        <!-- Decorative elements -->
        <div class="absolute -left-4 -top-4 h-72 w-72 rounded-full bg-primary-500/10 blur-3xl animate-blob"></div>
        <div class="absolute -right-4 -bottom-4 h-72 w-72 rounded-full bg-accent-500/10 blur-3xl animate-blob-delayed"></div>
        
        <!-- Image container -->
        <div class="group relative">
          <!-- Glowing border -->
          <div class="absolute -inset-1 rounded-3xl bg-gradient-to-r from-primary-500 via-accent-500 to-pink-500 opacity-20 blur-xl transition-all duration-700 group-hover:opacity-40"></div>
          
          <!-- Image wrapper -->
          <div class="relative overflow-hidden rounded-3xl border-2 border-white/20 bg-white/10 backdrop-blur-sm shadow-2xl">
            <Image
              src={paulaImg}
              alt="Paula Silveyra — Médica Veterinaria NeoVet"
              class="h-full w-full object-cover transition-all duration-700 group-hover:scale-105"
              width={600}
              height={750}
            />
            
            <!-- Overlay gradient -->
            <div class="absolute inset-0 bg-gradient-to-tr from-primary-500/20 via-transparent to-accent-500/20 opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
            
            <!-- Floating stats badge -->
            <div class="glass-card absolute left-6 top-6 animate-float">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-primary-500 to-primary-600 text-white shadow-lg">
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                </div>
                <div class="text-left">
                  <p class="text-xs font-semibold text-neutral-700">Especialista</p>
                  <p class="text-[10px] text-neutral-500">Mat. 2046</p>
                </div>
              </div>
            </div>

            <!-- Bottom floating badge -->
            <div class="glass-card absolute bottom-6 right-6 animate-float-delayed">
              <div class="flex items-center gap-2">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-accent-500 to-pink-500 text-lg shadow-lg">
                  🏆
                </div>
                <div class="text-left">
                  <p class="text-[10px] font-bold text-neutral-700">+10 años</p>
                  <p class="text-[9px] text-neutral-500">experiencia</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Content side -->
      <div class="space-y-8">
        
        <!-- Tag -->
        <div class="glass-tag inline-flex items-center gap-2">
          <div class="h-1.5 w-1.5 rounded-full bg-primary-500 animate-pulse"></div>
          Sobre nosotros
        </div>

        <!-- Title -->
        <div class="space-y-3">
          <h2 class="text-5xl font-black tracking-tight text-neutral-900 sm:text-6xl lg:text-7xl">
            <span class="block">Médica</span>
            <span class="block bg-gradient-to-r from-primary-600 via-accent-600 to-pink-600 bg-clip-text text-transparent animate-gradient">
              Veterinaria
            </span>
          </h2>
          <p class="text-2xl font-bold text-neutral-700">Paula Silveyra</p>
        </div>

        <!-- Description -->
        <p class="text-lg leading-relaxed text-neutral-600 max-w-xl">
          Especialista con formación académica de posgrado orientada a la excelencia clínica.
          <span class="font-semibold text-primary-600">Diplomada en medicina de braquicefálicos</span> y 
          <span class="font-semibold text-accent-600">Máster en ecografía</span>, dedicada a integrar
          la tecnología y el conocimiento especializado para el bienestar de cada paciente.
        </p>

        <!-- Feature cards -->
        <div class="grid gap-4 sm:grid-cols-2">
          
          <!-- Card 1 -->
          <div class="feature-card group/card">
            <div class="feature-card-glow"></div>
            <div class="relative z-10">
              <div class="mb-3 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br from-primary-500 to-primary-600 text-3xl shadow-lg transition-transform duration-300 group-hover/card:scale-110 group-hover/card:rotate-6">
                🐾
              </div>
              <h3 class="text-lg font-bold text-neutral-900 mb-1">Especialidad</h3>
              <p class="text-sm text-neutral-600">Bulldogs y razas braquicefálicas</p>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="feature-card group/card">
            <div class="feature-card-glow"></div>
            <div class="relative z-10">
              <div class="mb-3 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br from-accent-500 to-pink-500 text-3xl shadow-lg transition-transform duration-300 group-hover/card:scale-110 group-hover/card:rotate-6">
                🏥
              </div>
              <h3 class="text-lg font-bold text-neutral-900 mb-1">Guardia 24hs</h3>
              <p class="text-sm text-neutral-600">Atención obstétrica permanente</p>
            </div>
          </div>

        </div>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-4 pt-4">
          <a href="#servicios" class="btn-primary group/btn">
            <span class="relative z-10 flex items-center gap-2">
              Ver servicios
              <svg class="h-5 w-5 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
            <div class="btn-shimmer"></div>
          </a>
          
          <a href="#contacto" class="btn-secondary group/btn">
            <span class="flex items-center gap-2">
              Agendar turno
              <svg class="h-5 w-5 transition-transform duration-300 group-hover/btn:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </span>
          </a>
        </div>

      </div>

    </div>
  </div>
</section>

<style>
  /* Glass morphism cards */
  .glass-card {
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    padding: 0.75rem 1rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .glass-tag {
    border-radius: 9999px;
    border: 1px solid rgba(16, 185, 129, 0.2);
    background: rgba(236, 253, 245, 0.8);
    backdrop-filter: blur(8px);
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(4, 120, 87);
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }

  /* Animated grid background */
  .animated-grid {
    background-image: 
      linear-gradient(to right, rgba(16, 185, 129, 0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(16, 185, 129, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 20s linear infinite;
  }

  @keyframes gridMove {
    0% { background-position: 0 0; }
    100% { background-position: 50px 50px; }
  }

  /* Gradient animation for title */
  .animate-gradient {
    background-size: 200% auto;
    animation: gradient 3s ease infinite;
  }

  @keyframes gradient {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  /* Blob animation */
  .animate-blob {
    animation: blob 7s infinite;
  }

  .animate-blob-delayed {
    animation: blob 7s infinite 2s;
  }

  @keyframes blob {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
  }

  /* Float animation */
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 3s ease-in-out infinite 1s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  /* Feature cards */
  .feature-card {
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    border: 2px solid rgba(229, 231, 235, 0.5);
    background: white;
    padding: 1.5rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    transition: all 0.3s;
  }

  .feature-card:hover {
    border-color: rgba(16, 185, 129, 0.3);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    transform: translateY(-4px);
  }

  .feature-card-glow {
    position: absolute;
    inset: -4px;
    border-radius: 1rem;
    background: linear-gradient(to right, rgb(16, 185, 129), rgb(236, 72, 153));
    opacity: 0;
    filter: blur(24px);
    transition: opacity 0.5s;
  }

  .feature-card:hover .feature-card-glow {
    opacity: 0.2;
  }

  /* Primary button */
  .btn-primary {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    background: linear-gradient(to right, rgb(16, 185, 129), rgb(5, 150, 105));
    padding: 1rem 2rem;
    font-weight: 700;
    color: white;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    transition: all 0.3s;
  }

  .btn-primary:hover {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    transform: scale(1.05);
  }

  .btn-primary:active {
    transform: scale(0.95);
  }

  .btn-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.3), transparent);
    transform: translateX(-100%);
    transition: transform 0.7s;
  }

  .btn-primary:hover .btn-shimmer {
    transform: translateX(100%);
  }

  /* Secondary button */
  .btn-secondary {
    border-radius: 0.75rem;
    border: 2px solid rgb(209, 213, 219);
    background: white;
    padding: 1remz