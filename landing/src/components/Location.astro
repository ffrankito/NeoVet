---
---

<section id="ubicacion" class="bg-neutral-50 py-section" data-animate>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-600">
          Ubicación
        </p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
          ¿Dónde encontrarnos?
        </h2>

        <div class="mt-8 space-y-6">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary-100 text-primary-700">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0 1 15 0Z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-800">Dirección</p>
              <p class="text-sm text-neutral-500">Morrow 4064 (entre Robles y Forner), Rosario, Santa Fe</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary-100 text-primary-700">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-800">Teléfono / WhatsApp</p>
              <a href="tel:+543413101194" class="text-sm text-primary-600 hover:text-primary-800">
                (341) 310-1194
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary-100 text-primary-700">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-800">Email</p>
              <a href="mailto:veterinarianeo@gmail.com" class="text-sm text-primary-600 hover:text-primary-800">
                veterinarianeo@gmail.com
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Google Maps embed -->
      <div class="aspect-[4/3] overflow-hidden rounded-2xl border border-neutral-200">
        <iframe
          src="https://maps.google.com/maps?q=-32.95746,-60.64653&z=17&output=embed&hl=es"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación NeoVet — Morrow 4064, Rosario"
        ></iframe>
      </div>
    </div>
  </div>
</section>
<style>
  /* Animación de entrada de la sección */
  #ubicacion > div {
    animation: fadeIn 0.8s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Cards de contacto con animación escalonada */
  #ubicacion .space-y-6 > div {
    animation: slideInLeft 0.6s ease-out both;
  }

  #ubicacion .space-y-6 > div:nth-child(1) { animation-delay: 0.1s; }
  #ubicacion .space-y-6 > div:nth-child(2) { animation-delay: 0.2s; }
  #ubicacion .space-y-6 > div:nth-child(3) { animation-delay: 0.3s; }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Hover en los íconos */
  #ubicacion .bg-primary-100 {
    transition: all 0.3s ease;
  }

  #ubicacion .flex.items-start:hover .bg-primary-100 {
    background: linear-gradient(135deg, #10b981, #059669);
    transform: scale(1.1) rotate(5deg);
  }

  #ubicacion .flex.items-start:hover .bg-primary-100 svg {
    color: white;
  }

  /* Animación del ícono en hover */
  #ubicacion .bg-primary-100 svg {
    transition: all 0.3s ease;
  }

  #ubicacion .flex.items-start:hover .bg-primary-100 svg {
    animation: iconBounce 0.6s ease;
  }

  @keyframes iconBounce {
    0%, 100% { transform: translateY(0); }
    25% { transform: translateY(-5px); }
    75% { transform: translateY(-3px); }
  }

  /* Links con underline animado */
  #ubicacion a[href^="tel"],
  #ubicacion a[href^="mailto"] {
    position: relative;
    display: inline-block;
    transition: color 0.3s ease;
  }

  #ubicacion a[href^="tel"]::after,
  #ubicacion a[href^="mailto"]::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: currentColor;
    transition: width 0.3s ease;
  }

  #ubicacion a[href^="tel"]:hover::after,
  #ubicacion a[href^="mailto"]:hover::after {
    width: 100%;
  }

  /* Mapa con animación de entrada */
  #ubicacion iframe {
    animation: slideInRight 0.8s ease-out 0.3s both;
    transition: transform 0.3s ease;
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Zoom suave en el mapa */
  #ubicacion .aspect-\[4\/3\] {
    position: relative;
    overflow: hidden;
  }

  #ubicacion .aspect-\[4\/3\]::before {
    content: '📍';
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
    font-size: 2rem;
    animation: pinBounce 2s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes pinBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  #ubicacion .aspect-\[4\/3\]:hover iframe {
    transform: scale(1.02);
  }

  /* Border con gradiente animado */
  #ubicacion .aspect-\[4\/3\] {
    border: 2px solid transparent;
    background: linear-gradient(white, white) padding-box,
                linear-gradient(135deg, #10b981, #059669) border-box;
    border-radius: 1rem;
  }
</style>