---
import ServiceCard from './ServiceCard.astro';

const whatsappEcografia =
  "https://api.whatsapp.com/send/?phone=543413101194&text=Hola%2C%20quiero%20solicitar%20una%20ecograf%C3%ADa%20a%20domicilio&type=phone_number&app_absent=0";
const whatsappBraquicefalicos =
  "https://api.whatsapp.com/send/?phone=543413101194&text=Hola%2C%20quiero%20una%20consulta%20para%20paciente%20braquicef%C3%A1lico&type=phone_number&app_absent=0";
const whatsappReproduccion =
  "https://api.whatsapp.com/send/?phone=543413101194&text=Hola%2C%20quiero%20asesoramiento%20en%20reproducci%C3%B3n&type=phone_number&app_absent=0";
const whatsappUrl =
  "https://api.whatsapp.com/send/?phone=543413101194&text&type=phone_number&app_absent=0";

const specialties = [
  {
    title: "Diagnóstico de Precisión: Ecografía de Alta Complejidad en consultorio y a domicilio",
    description: "Llevamos la precisión diagnóstica donde más se necesita. Contamos con equipos portátiles de última generación para realizar estudios abdominales y cardiológicos con nivel de posgrado, garantizando comodidad para tu mascota y resultados inmediatos sin traslados innecesarios.",
    badge: "Máster en Ecografía",
    icon: "🔬",
    cta: "Solicitar ecografía a domicilio",
    href: whatsappEcografia,
  },
  {
    title: "Expertos en Cuidados de Razas Braquicefálicas",
    description: "Entendemos la anatomía y las necesidades únicas de pacientes como el Bulldog o el Pug. Ofrecemos un abordaje clínico y quirúrgico especializado para mejorar su calidad de vida y garantizar su seguridad en cada procedimiento.",
    badge: "Diplomada en Braquicefálicos",
    icon: "🐾",
    cta: "Consulta para pacientes braquicefálicos",
    href: whatsappBraquicefalicos,
  },
  {
    title: "Reproducción Veterinaria y Cuidado Neonatal",
    description: "Acompañamos cada etapa del ciclo reproductivo con profesionalismo. Desde el seguimiento folicular y diagnóstico de gestación hasta la atención del recién nacido, priorizando siempre la salud de la madre y su camada.",
    badge: "Reproducción y Neonatología",
    icon: "🏥",
    cta: "Asesoramiento en reproducción",
    href: whatsappReproduccion,
  },
];

const services = [
  {
    title: "Cirugía General",
    description: "Procedimientos quirúrgicos con equipamiento moderno y protocolos de seguridad.",
    icon: "🏥",
  },
  {
    title: "Cardiología",
    description: "Diagnóstico y tratamiento de patologías cardíacas en pequeños animales.",
    icon: "❤️",
  },
  {
    title: "Vacunación y Desparasitación",
    description: "Plan sanitario completo. Vacunas y antiparasitarios al día.",
    icon: "💉",
  },
  {
    title: "Radiografía",
    description: "Estudios radiológicos para diagnóstico óseo, torácico y abdominal.",
    icon: "🩻",
  },
  {
    title: "Internación",
    description: "Seguimiento y cuidado de pacientes que requieren hospitalización.",
    icon: "🏨",
  },
  {
    title: "Certificados",
    description: "Certificados sanitarios, de salud y documentación oficial para tu mascota.",
    icon: "📋",
  },
  {
    title: "Alimentación y Pet Shop",
    description: "Alimentos, accesorios y medicamentos veterinarios en un solo lugar.",
    icon: "🛒",
  },
  {
    title: "Peluquería Canina",
    description: "Baño, corte y cuidado estético profesional para tu mascota.",
    icon: "✂️",
  },
];
---

<!-- Especialidades -->
<section id="especialidades" class="bg-neutral-50 py-section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary-600">
        Especialidades
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
        Formación de posgrado al servicio de tu mascota
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-neutral-500">
        Áreas de atención donde la experiencia y la tecnología marcan la diferencia.
      </p>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      {specialties.map((s) => (
        <ServiceCard
          href={s.href}
          cta={s.cta}
          icon={s.icon}
          title={s.title}
          description={s.description}
          badge={s.badge}
          featured={true}
        />
      ))}
    </div>
  </div>
</section>

<!-- Servicios generales -->
<section id="servicios" class="bg-white py-section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary-600">
        Nuestros servicios
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
        ¿Qué servicios ofrecemos?
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-neutral-500">
        Brindamos atención integral para tu mascota con profesionalismo y dedicación.
      </p>
    </div>

    <div class="mt-16 grid gap-3 sm:gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((s) => (
        <ServiceCard
          href={whatsappUrl}
          cta="Consultar"
          icon={s.icon}
          title={s.title}
          description={s.description}
        />
      ))}
    </div>
  </div>
</section>