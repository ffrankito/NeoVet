---
const whatsappUrl =
  "https://api.whatsapp.com/send/?phone=543413101194&text&type=phone_number&app_absent=0";

const schedule = [
  { day: "Lunes a Sábado", hours: "9:30 – 12:30 / 16:30 – 20:00", open: true },
  { day: "Feriados", hours: "10:00 – 13:00", open: true },
  { day: "Domingo", hours: "Guardia pasiva 9:00–20:00", open: false, note: "Llamar para consultar atención" },
  { day: "Guardia Obstétrica", hours: "Disponible las 24hs", open: true, highlight: true },
];
---

<section id="horarios" class="bg-white py-section" data-animate>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary-600">
        Horarios
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
        Horarios de atención
      </h2>
      <p class="mt-4 text-lg text-neutral-500">
        <!-- PLACEHOLDER: confirm hours with Paula -->
        Nos encontramos disponibles en los siguientes horarios.
      </p>
    </div>

    <div class="mx-auto mt-12 max-w-xl">
      <div class="divide-y divide-neutral-200 overflow-hidden rounded-2xl border border-neutral-200">
        {schedule.map((item) => (
          <div
            class:list={[
              "flex items-center justify-between px-6 py-5",
              item.highlight && "bg-accent-50",
              !item.open && !item.highlight && "bg-neutral-50",
            ]}
          >
            <div class="flex items-center gap-3">
              <span
                class:list={[
                  "h-2.5 w-2.5 rounded-full",
                  item.highlight ? "bg-accent-500" : item.open ? "bg-whatsapp" : "bg-neutral-300",
                ]}
                aria-hidden="true"
              ></span>
              <span class="font-medium text-neutral-800">{item.day}</span>
            </div>
            <div class="text-right">
              <span
                class:list={[
                  "block text-sm",
                  item.highlight ? "font-semibold text-accent-700" : "text-neutral-500",
                ]}
              >
                {item.hours}
              </span>
              {item.note && (
                <span class="block text-xs text-neutral-400">{item.note}</span>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <p class="text-sm text-neutral-500">
          ¿Tenés una urgencia fuera de horario?
        </p>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-flex items-center gap-2 text-sm font-semibold text-whatsapp-dark transition-colors hover:text-primary-800"
        >
          Escribinos por WhatsApp
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
<style>
  /* Animación del contenedor */
  #horarios .max-w-xl {
    animation: fadeInUp 0.8s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Animación escalonada de las filas */
  #horarios .divide-y > div {
    animation: slideIn 0.5s ease-out both;
  }

  #horarios .divide-y > div:nth-child(1) { animation-delay: 0.1s; }
  #horarios .divide-y > div:nth-child(2) { animation-delay: 0.2s; }
  #horarios .divide-y > div:nth-child(3) { animation-delay: 0.3s; }
  #horarios .divide-y > div:nth-child(4) { animation-delay: 0.4s; }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Hover en cada fila */
  #horarios .divide-y > div {
    transition: all 0.3s ease;
    cursor: default;
  }

  #horarios .divide-y > div:hover {
    background: #f0fdf4 !important;
    transform: translateX(8px);
  }

  /* Pulso en el indicador verde */
  #horarios .bg-whatsapp {
    position: relative;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(34, 197, 94, 0);
    }
  }

  /* Animación especial para guardia obstétrica */
  #horarios .bg-accent-500 {
    animation: glowPulse 2s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.7);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(245, 158, 11, 0);
    }
  }

  /* Badge de emergencia con animación */
  #horarios .bg-accent-50 {
    position: relative;
    overflow: hidden;
  }

  #horarios .bg-accent-50::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(245, 158, 11, 0.1), transparent);
    animation: shimmer 3s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  /* Link de WhatsApp con flecha animada */
  #horarios .mt-8 a {
    position: relative;
    transition: all 0.3s ease;
  }

  #horarios .mt-8 a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: currentColor;
    transition: width 0.3s ease;
  }

  #horarios .mt-8 a:hover::after {
    width: 100%;
  }

  #horarios .mt-8 a svg {
    transition: transform 0.3s ease;
  }

  #horarios .mt-8 a:hover svg {
    transform: translateX(5px);
  }

  /* Efecto de brillo en el contenedor */
  #horarios .rounded-2xl {
    position: relative;
    overflow: hidden;
  }

  #horarios .rounded-2xl::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent,
      rgba(16, 185, 129, 0.05),
      transparent
    );
    transform: rotate(45deg);
    animation: shine 4s ease-in-out infinite;
  }

  @keyframes shine {
    0% { left: -50%; }
    50% { left: 150%; }
    100% { left: 150%; }
  }
</style>