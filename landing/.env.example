# Sentry — get DSN from: sentry.io → ravena/neovet-landing → Settings → Client Keys (DSN)
# Astro convention: vars exposed to the browser MUST be prefixed PUBLIC_.
# Auth token from: sentry.io/settings/auth-tokens/ (scopes: project:releases, org:read).
# Same token works across projects in the ravena org.
PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=ravena
SENTRY_PROJECT=neovet-landing
