        </mxCell>
        <mxCell id="kapso" value="&lt;b&gt;Kapso (v2)&lt;/b&gt;&lt;br&gt;[External System]&lt;br&gt;&lt;br&gt;WhatsApp channel" style="rounded=0;fillColor=#cccccc;strokeColor=#6c6c6c;fontColor=#000000;fontSize=11;fontStyle=1;whiteSpace=wrap;html=1;dashed=1" vertex="1" parent="1">
          <mxGeometry x="200" y="440" width="180" height="100" as="geometry" />
