<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="c4-context" name="C4 — Context">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" pageWidth="1600" pageHeight="1000" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;C4 Level 1 — System Context&lt;/b&gt;&lt;br&gt;NeoVet as a black box + its users and external systems" style="text;html=1;align=left;fontSize=16" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="notes" value="&lt;b&gt;C4 Context = single box for the system, actors around it.&lt;/b&gt;&lt;br&gt;Good for: onboarding, Paula-facing explanations, scope boundaries.&lt;br&gt;&lt;br&gt;Rules:&lt;br&gt;&amp;bull; Don't show internal structure (that's Container on page 2)&lt;br&gt;&amp;bull; Label every line with what flows (data? command?)&lt;br&gt;&amp;bull; Mark Geovet explicitly as LEGACY / being replaced" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="neovet" value="&lt;b&gt;NeoVet&lt;/b&gt;&lt;br&gt;[Software System]&lt;br&gt;&lt;br&gt;CRM + Chatbot + Landing" style="rounded=0;fillColor=#1168bd;strokeColor=#0b4884;fontColor=#ffffff;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1" vertex="1" parent="1">
          <mxGeometry x="720" y="440" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cliente" value="&lt;b&gt;Cliente&lt;/b&gt;&lt;br&gt;[Persona]&lt;br&gt;&lt;br&gt;Dueño de mascota" style="shape=umlActor;fillColor=#08427b;strokeColor=#073b6f;fontColor=#ffffff;fontSize=11;whiteSpace=wrap;html=1" vertex="1" parent="1">
          <mxGeometry x="440" y="200" width="80" height="140" as="geometry" />
        </mxCell>
        <mxCell id="paula" value="&lt;b&gt;Paula / Staff&lt;/b&gt;&lt;br&gt;[Persona]&lt;br&gt;&lt;br&gt;admin / owner / vet / groomer" style="shape=umlActor;fillColor=#08427b;strokeColor=#073b6f;fontColor=#ffffff;fontSize=11;whiteSpace=wrap;html=1" vertex="1" parent="1">
          <mxGeometry x="1120" y="200" width="80" height="140" as="geometry" />
        </mxCell>
