        </mxCell>
        <mxCell id="resend" value="&lt;b&gt;Resend&lt;/b&gt;&lt;br&gt;[External System]&lt;br&gt;&lt;br&gt;Email delivery" style="rounded=0;fillColor=#999999;strokeColor=#6c6c6c;fontColor=#ffffff;fontSize=11;fontStyle=1;whiteSpace=wrap;html=1" vertex="1" parent="1">
