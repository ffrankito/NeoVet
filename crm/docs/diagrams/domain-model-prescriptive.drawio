                    <mxGeometry x="560" y="250" width="250" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="note_charge" value="&lt;b style=&quot;color:#006100&quot;&gt;✔ Fix 2: Typed Charge FKs&lt;/b&gt;&lt;br&gt;Replaced polymorphic (sourceType, sourceId) with 5 nullable FKs to real aggregates + a CHECK constraint that exactly one is set. DB now enforces integrity; cascades work on source deletion; the &quot;debtors&quot; query still joins on clientId.&lt;br&gt;&lt;i&gt;See dashed edges to each source.&lt;/i&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" parent="1" vertex="1">
                    <mxGeometry x="850" y="1036.7700000000002" width="260" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="note_followup" value="&lt;b style=&quot;color:#006100&quot;&gt;✔ Fix 3: FollowUp split&lt;/b&gt;&lt;br&gt;Replaced the either-or FollowUp with two dedicated types:&lt;br&gt;&amp;bull; ConsultationFollowUp — owned by Consultation&lt;br&gt;&amp;bull; ProcedureFollowUp — owned by Procedure&lt;br&gt;Each has a real FK, cascade semantics, and a clear owner. Shared UI lists can still union them for the vet&#39;s pending-items view." style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" parent="1" vertex="1">
                    <mxGeometry x="1140" y="200" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="note_staff_refs" value="&lt;b&gt;Note&lt;/b&gt;&lt;br&gt;Staff is referenced by many aggregates (createdById, recordedById, soldById, etc.). Those audit-trail references are omitted for clarity — they are NOT aggregate relationships, just user-tracking metadata." style="shape=note;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" parent="1" vertex="1">
                    <mxGeometry x="1760" y="200" width="200" height="110" as="geometry"/>
                </mxCell>
