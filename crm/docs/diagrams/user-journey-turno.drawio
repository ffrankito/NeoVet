  <diagram id="user-journey" name="User Journey — Cliente quiere turno">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" pageWidth="1800" pageHeight="1100" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;User Journey — Cliente quiere turno&lt;/b&gt;&lt;br&gt;From first touchpoint to attended consultation. Compare v1 (web widget + manual) vs v2 (WhatsApp + auto)." style="text;html=1;align=left;fontSize=16" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1600" height="50" as="geometry" />
        </mxCell>
        <mxCell id="notes" value="&lt;b&gt;Fill each cell. Keep it honest — no imaginary flows.&lt;/b&gt;&lt;br&gt;&amp;bull; Touchpoint: what the client interacts with (landing, widget, WhatsApp, cartel)&lt;br&gt;&amp;bull; Action: what they do&lt;br&gt;&amp;bull; Emotion: Paula says clients are anxious about brachy breeds — capture that&lt;br&gt;&amp;bull; Pain points: where it breaks today (duplicate calendars, manual confirm, no reminder)&lt;br&gt;&amp;bull; Opportunity: what v1/v2/v3 fixes" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="420" height="170" as="geometry" />
        </mxCell>
