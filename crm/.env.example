# Supabase — get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database — Transaction mode, port 6543 (used by the app at runtime)
# Get from: Settings → Database → Connection string → Transaction mode
# Also add a SESSION mode (port 5432) version to .env (not .env.local) for drizzle-kit migrations
DATABASE_URL=

# Email — Resend (https://resend.com/api-keys)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
# En producción usar el dominio verificado, ej: "NeoVet <turnos@neovet.com.ar>"

# Clinic info — used in email templates and schedule-block cancellation messages.
# Default if unset: "Morrow 4064, Rosario"
CLINIC_ADDRESS=

# Cron & Admin routes — string random largo, mismo valor en Vercel
CRON_SECRET=

# Bot API — protege /api/bot/* (usado por el chatbot en v2)
BOT_API_KEY=

# Sentry — get DSN from: sentry.io → your project → Settings → Client Keys (DSN)
# Auth token from: sentry.io/settings/auth-tokens/ (scopes: project:releases, org:read)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
