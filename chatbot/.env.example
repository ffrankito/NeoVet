# Anthropic — get from: console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase — used by the WhatsApp bot's session layer
# (bot_contacts, bot_conversations, bot_messages)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# CRM — base URL of the CRM deployment (the bot is a CRM client).
# Do NOT include a trailing /dashboard — the bot calls ${CRM_URL}/api/bot/*
CRM_URL=

# CRM bot API — must match the CRM's BOT_API_KEY exactly.
# Generate with: openssl rand -hex 32
BOT_API_KEY=

# Kapso (WhatsApp Business provider) — sent as X-API-Key when calling api.kapso.ai
KAPSO_API_KEY=

# Sentry — DSN from sentry.io → ravena/neovet-chatbot → Settings → Client Keys (DSN)
# Auth token from sentry.io/settings/auth-tokens/
# (scopes: project:releases, org:read — works across projects in the ravena org)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=ravena
SENTRY_PROJECT=neovet-chatbot
