# Anthropic — get from: console.anthropic.com
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Kapso + WhatsApp — v2 only, leave empty for v1
# KAPSO_API_KEY=
# KAPSO_WEBHOOK_SECRET=          # generate with: openssl rand -hex 32
# WHATSAPP_PHONE_NUMBER_ID=

# Sentry — get DSN from: sentry.io → ravena/neovet-chatbot → Settings → Client Keys (DSN)
# Auth token from: sentry.io/settings/auth-tokens/ (scopes: project:releases, org:read; same token works across projects in the ravena org)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=ravena
SENTRY_PROJECT=neovet-chatbot



